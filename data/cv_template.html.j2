<!doctype html><html><head><meta charset="utf-8">
<style>
 body{font-family:Arial,Helvetica,sans-serif;color:#141414;margin:32px;font-size:12px;line-height:1.4}
 h1{font-size:22px;margin:0;color:#0b5} .muted{color:#555}
 h2{font-size:13px;text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid #ddd;margin-top:18px}
 .item{margin:8px 0} .role{font-weight:bold} ul{margin:4px 0 4px 18px}
</style></head><body>
 <h1>{{ basics.name }}</h1>
 <div class="muted">{{ basics.label }}{% if basics.location %} · {{ basics.location }}{% endif %}
   {% if basics.email %} · {{ basics.email }}{% endif %}{% if basics.url %} · {{ basics.url }}{% endif %}</div>
 {% if basics.summary %}<p>{{ basics.summary }}</p>{% endif %}
 {% if work %}<h2>Experience</h2>{% for w in work %}<div class="item">
   <div class="role">{{ w.position }} — {{ w.name }} <span class="muted">{{ w.startDate }}–{{ w.endDate or "present" }}</span></div>
   {% if w.summary %}<div>{{ w.summary }}</div>{% endif %}
   {% if w.highlights %}<ul>{% for h in w.highlights %}<li>{{ h }}</li>{% endfor %}</ul>{% endif %}
 </div>{% endfor %}{% endif %}
 {% if skills %}<h2>Skills</h2><div>{% for s in skills %}{{ s.name }}{% if s.keywords %}: {{ s.keywords|join(", ") }}{% endif %}{% if not loop.last %} · {% endif %}{% endfor %}</div>{% endif %}
 {% if education %}<h2>Education</h2>{% for e in education %}<div class="item">{{ e.studyType }} {{ e.area }} — {{ e.institution }} <span class="muted">{{ e.startDate }}–{{ e.endDate }}</span></div>{% endfor %}{% endif %}
 {% if languages %}<h2>Languages</h2><div>{% for l in languages %}{{ l.language }} ({{ l.fluency }}){% if not loop.last %} · {% endif %}{% endfor %}</div>{% endif %}
</body></html>
