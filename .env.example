# ── AI backend ────────────────────────────────────────────────────────────────
# Gradian Match runs on YOUR own AI. Two ways to connect it — pick one:
#
#   1) Claude Code (default, no key needed): install Claude Code and sign in.
#      Leave everything below blank. Uses your Claude subscription.
#   2) Anthropic API key (faster, cheaper per run): paste your key below.
#      Get one at https://console.anthropic.com/ .
ANTHROPIC_API_KEY=
# Force a backend: auto (default) | cli (Claude Code) | api (Anthropic key)
GM_BACKEND=auto
# Override the model (optional). Default is claude-opus-4-8 for the API backend,
# or your own default for Claude Code. For faster/cheaper runs try claude-sonnet-5.
GM_MODEL=

# ── Job Finder (all optional) ──────────────────────────────────────────────────
# Only needed for extra Job Finder coverage. Core analyze/regenerate needs NONE of these.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_KEY=
# Optional — higher GitHub API rate limits for source verification
GITHUB_TOKEN=
